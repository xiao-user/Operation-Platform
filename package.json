{
  "name": "operation-platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "check": "run-s lint type-check test build-only",
    "build-only": "vite build",
    "type-check": "run-p type-check:app type-check:test type-check:e2e",
    "type-check:app": "vue-tsc --build",
    "type-check:test": "vue-tsc --noEmit -p tsconfig.test.json",
    "type-check:e2e": "tsc --noEmit -p tsconfig.e2e.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "map:refresh:rongcheng": "node scripts/fetch-rongcheng-townships.mjs",
    "map:refresh:rongcheng-context": "node scripts/fetch-rongcheng-regional-context.mjs",
    "map:normalize:rongcheng": "node scripts/normalize-map-json.mjs src/assets/maps/rongcheng-townships.json",
    "lint": "run-p lint:check:oxlint lint:check:eslint",
    "lint:check:oxlint": "oxlint .",
    "lint:check:eslint": "eslint .",
    "lint:fix": "run-s lint:fix:oxlint lint:fix:eslint",
    "lint:fix:oxlint": "oxlint . --fix",
    "lint:fix:eslint": "eslint . --fix --cache"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@lucide/vue": "1.22.0",
    "element-plus": "^2.13.5",
    "gridstack": "^12.6.0",
    "gsap": "^3.15.0",
    "pinia": "^3.0.4",
    "three": "^0.185.1",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.11.0",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.2",
    "eslint-plugin-oxlint": "~1.50.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.50.0",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
